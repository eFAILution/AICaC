{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/eFAILution/AICaC/spec/v2/workflows.schema.json",
  "title": "AICaC workflows.yaml",
  "description": "Common tasks, exact commands, and multi-step procedures. Canonical form: dict keyed by workflow id.",
  "type": "object",
  "required": ["version", "workflows"],
  "properties": {
    "version": { "type": "string", "pattern": "^(1|2)\\.[0-9]+(\\.[0-9]+)?$" },
    "summary": { "type": "string", "maxLength": 280 },
    "workflows": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "description": { "type": "string", "minLength": 5 },
          "command": { "type": "string" },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["action"],
              "properties": {
                "action": { "type": "string" },
                "command": { "type": "string" },
                "location": { "type": "string" },
                "file": { "type": "string" },
                "note": { "type": "string" },
                "template": { "type": "string" }
              },
              "additionalProperties": true
            }
          },
          "options": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "prerequisites": {
            "type": "array",
            "items": { "type": "string" }
          },
          "estimated_time": { "type": "string" },
          "reference": { "type": "string" },
          "reference_implementation": { "type": "string" },
          "touches_components": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Component ids touched by this workflow (enables cross-ref validation)."
          }
        },
        "anyOf": [
          { "required": ["command"] },
          { "required": ["steps"] }
        ],
        "additionalProperties": true
      }
    },
    "testing": {
      "type": "object",
      "additionalProperties": { "type": "object" }
    },
    "common_issues": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "symptom": { "type": "string" },
          "solution": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": true
}
